# Docker network overrides (loaded after .env)
# Keeps local .env untouched while making containers talk to compose services.

DATABASE_URL=postgres://reconeye:reconeye@postgres:5432/reconeye
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CACHE_URL=redis://redis:6379/3
